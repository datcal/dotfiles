quick-terminal-position = top
quit-after-last-window-closed = false
keybind = F12=toggle_quick_terminal

# Appearance
theme = TokyoNight
font-family = JetBrainsMono Nerd Font
font-size = 12
cursor-style = block
window-padding-x = 8
window-padding-y = 8

# Behavior
mouse-hide-while-typing = true
copy-on-select = clipboard
confirm-close-surface = false

# Copy/paste: selecting text auto-copies (above). Ctrl+Shift+C is an explicit
# copy; paste works on BOTH Ctrl+V and Ctrl+Shift+V. Ctrl+C stays as interrupt.
keybind = ctrl+shift+c=copy_to_clipboard
keybind = ctrl+v=paste_from_clipboard
keybind = ctrl+shift+v=paste_from_clipboard

# Font size (makes text bigger/smaller everywhere, including inside Neovim):
# Ctrl++ grows, Ctrl+- shrinks, Ctrl+0 resets to the default above.
keybind = ctrl+equal=increase_font_size:1
keybind = ctrl+plus=increase_font_size:1
keybind = ctrl+minus=decrease_font_size:1
keybind = ctrl+zero=reset_font_size
